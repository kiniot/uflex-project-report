@startuml uflex-sa-containers
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

' Styling approximations for Structurizr look (blue & gray palette)
skinparam shadowing false
skinparam defaultFontName Arial
skinparam Handwritten false
skinparam Padding 3
skinparam wrapWidth 200
skinparam nodesep 40
skinparam ranksep 60

LAYOUT_WITH_LEGEND()

' ---- Tags / legend ----
AddPersonTag("internal",       $bgColor="#4A6FA5", $fontColor="#ffffff", $borderColor="#2F4A73", $legendText="Usuario interno (uFlex)")
AddSystemTag("external",       $bgColor="#999999", $fontColor="#ffffff", $borderColor="#6B6B6B", $legendText="Sistema externo")
AddContainerTag("mobile",      $bgColor="#438DD5", $fontColor="#ffffff", $borderColor="#2E6295", $legendText="App móvil nativa")
AddContainerTag("web",         $bgColor="#438DD5", $fontColor="#ffffff", $borderColor="#2E6295", $legendText="Aplicación web / PWA")
AddContainerTag("gateway",     $bgColor="#0B4884", $fontColor="#ffffff", $borderColor="#062F5A", $legendText="API Gateway")
AddContainerTag("service",     $bgColor="#1168BD", $fontColor="#ffffff", $borderColor="#0B4884", $legendText="Microservicio (backend)")
AddContainerTag("database",    $bgColor="#85BBF0", $fontColor="#000000", $borderColor="#438DD5", $legendText="Base de datos")
AddContainerTag("iot",         $bgColor="#708090", $fontColor="#ffffff", $borderColor="#4F5B66", $legendText="Firmware IoT (embedded)")
AddContainerTag("edge",        $bgColor="#B0C4DE", $fontColor="#000000", $borderColor="#708090", $legendText="Edge computing")
AddContainerTag("iotHardware", $bgColor="#4F5B66", $fontColor="#ffffff", $borderColor="#2F3840", $legendText="Hardware IoT propio (sensor IMU)")

title Container Diagram for uFlex (KinIoT)

' =========================================================
' Actors (top row)
' =========================================================
Person(patient,         "Paciente",                 "Realiza terapia de miembro superior", $tags="internal")
Person(physiotherapist, "Fisioterapeuta",           "Supervisa sesiones y ajusta protocolos", $tags="internal")
Person(clinicAdmin,     "Administrador de Clínica", "Gestiona sedes, usuarios y suscripción", $tags="internal")

' =========================================================
' uFlex system
' =========================================================
System_Boundary(uflex, "uFlex") {

  ' ---- IoT Tier ----
  Boundary(iotTier, "IoT & Edge Tier") {
    Container(imuSensor,    "IMU Sensor Device", "Hardware propio KinIoT", "Sensor vestible (muñeca/codo) que captura aceleración y orientación", $tags="iotHardware")
    Container(embeddedApp,  "Embedded App",      "C++",                     "Firmware del sensor IMU: muestreo, filtrado y transmisión BLE", $tags="iot")
    Container(edgeApp,      "Edge App",          "Python",                  "Procesamiento biomecánico y retroalimentación AI en tiempo real", $tags="edge")
    ContainerDb(edgeDB,     "Edge DB",           "SQLite",                  "Buffer local de muestras biomecánicas", $tags="database")
  }

  ' ---- Client Tier ----
  Boundary(clientTier, "Client Apps Tier") {
    Container(mobileApp,    "Mobile App",       "Swift/SwiftUI (iOS), Kotlin/Jetpack Compose (Android)", "App del paciente: rutinas, feedback y sincronización con el sensor", $tags="mobile")
    ContainerDb(mobileDB,   "Mobile DB",        "SQLite",               "Caché local del paciente (rutinas, progreso)", $tags="database")
    Container(webClientApp, "Web Client App",   "TypeScript, Angular",  "PWA para fisioterapeutas y administradores de clínica", $tags="web")
  }

  ' ---- API Gateway ----
  Container(apiGateway, "API Gateway", "AWS API Gateway", "Enruta requests y aplica autenticación/cuotas", $tags="gateway")

  ' ---- Backend Services Tier ----
  Boundary(backendTier, "Backend Services Tier") {
    Container(iamService,          "IAM Service",             "Java, Spring Boot", "Gestiona roles, tenants y perfiles clínicos (delega OAuth a Supabase)", $tags="service")
    ContainerDb(iamDB,             "IAM DB",                  "PostgreSQL",        "Perfiles, roles y políticas de acceso", $tags="database")

    Container(therapyService,      "Therapy Session Service", "Java, Spring Boot", "Gestiona sesiones de terapia y métricas biomecánicas", $tags="service")
    ContainerDb(therapyDB,         "Therapy DB",              "Oracle",            "Sesiones, ROM, repeticiones y calidad de ejecución", $tags="database")

    Container(trendsService,       "Clinical Trends Service", "Java, Spring Boot", "Consolida tendencias clínicas por paciente y protocolo", $tags="service")
    ContainerDb(trendsDB,          "Trends DB",               "Oracle",            "Series agregadas de evolución clínica", $tags="database")

    Container(subscriptionService, "Subscription Service",    "Java, Spring Boot", "Gestiona suscripciones multi-tenant de clínicas", $tags="service")
    ContainerDb(subscriptionDB,    "Subscription DB",         "Oracle",            "Planes, tenants y estado de facturación", $tags="database")

    Container(analyticsService,    "Analytics Service",       "Java, Spring Boot", "Genera KPIs clínicos y de negocio", $tags="service")
    ContainerDb(analyticsDB,       "Analytics DB",            "Oracle",            "Datasets analíticos anonimizados", $tags="database")

    Container(notificationService, "Notification Service",    "Java, Spring Boot", "Orquesta correos transaccionales y notificaciones", $tags="service")
  }
}

' =========================================================
' External systems (bottom)
' =========================================================
System_Ext(supabase, "Supabase (OAuth)", "Proveedor de autenticación e identidad", $tags="external")
System_Ext(stripe,   "Stripe",           "Pasarela de pagos", $tags="external")
System_Ext(resend,   "Resend",           "Envío de correos transaccionales", $tags="external")

' =========================================================
' Relations — users to clients
' =========================================================
Rel(patient,         mobileApp,    "Ejecuta rutinas y revisa feedback")
Rel(physiotherapist, webClientApp, "Revisa sesiones y ajusta protocolos")
Rel(clinicAdmin,     webClientApp, "Administra clínica y suscripción")

' ---- Clients to edge / storage / gateway ----
Rel(mobileApp, embeddedApp, "Controla sesión del sensor (BLE)")
Rel(mobileApp, edgeApp,     "Sincroniza datos vía Facade")
Rel(mobileApp, mobileDB,    "Lee/escribe caché local")
Rel(mobileApp, apiGateway,  "Consume servicios cloud (HTTPS)")
Rel(webClientApp, apiGateway, "Consume servicios cloud (HTTPS)")

' ---- IoT chain ----
Rel(embeddedApp, imuSensor, "Lee IMU y controla hardware")
Rel(embeddedApp, edgeApp,   "Envía muestras biomecánicas")
Rel(edgeApp,     edgeDB,    "Persiste muestras locales")
Rel(edgeApp,     apiGateway,"Envía datos anonimizados")

' ---- Gateway to services ----
Rel(apiGateway, iamService,          "Rutea identidad/roles")
Rel(apiGateway, therapyService,      "Rutea sesiones")
Rel(apiGateway, trendsService,       "Rutea tendencias")
Rel(apiGateway, subscriptionService, "Rutea suscripciones")
Rel(apiGateway, analyticsService,    "Rutea analítica")

' ---- Services to own DBs ----
Rel(iamService,          iamDB,          "Persiste perfiles y roles")
Rel(therapyService,      therapyDB,      "Persiste sesiones")
Rel(trendsService,       trendsDB,       "Persiste tendencias")
Rel(subscriptionService, subscriptionDB, "Persiste suscripciones")
Rel(analyticsService,    analyticsDB,    "Persiste datasets analíticos")

' ---- Service-to-service ----
Rel(analyticsService,    trendsService,       "Consume tendencias")
Rel(analyticsService,    therapyService,      "Consume sesiones")
Rel(therapyService,      notificationService, "Solicita notificaciones clínicas")
Rel(subscriptionService, notificationService, "Solicita avisos de facturación")

' ---- Clients & services to externals ----
Rel(mobileApp,           supabase, "Autentica al paciente (OAuth)")
Rel(webClientApp,        supabase, "Autentica/autoriza profesionales (OAuth)")
Rel(iamService,          supabase, "Valida tokens OAuth")
Rel(subscriptionService, stripe,   "Procesa pagos de suscripción")
Rel(notificationService, resend,   "Envía correos transaccionales")

@enduml
