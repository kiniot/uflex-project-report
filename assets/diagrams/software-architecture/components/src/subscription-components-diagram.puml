@startuml uflex-subscription-component
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

' Styling
skinparam shadowing false
skinparam defaultFontName Arial
skinparam Handwritten false
skinparam Padding 3
skinparam wrapWidth 200
skinparam nodesep 35
skinparam ranksep 55

' ---- Tags ----
AddContainerTag("webApp",         $bgColor="#438DD5", $fontColor="#ffffff", $borderColor="#2E6295", $legendText="Web Client App PWA")
AddContainerTag("iamService",     $bgColor="#1168BD", $fontColor="#ffffff", $borderColor="#0B4884", $legendText="IAM Service — sibling microservice")
AddContainerTag("notifService",   $bgColor="#1168BD", $fontColor="#ffffff", $borderColor="#0B4884", $legendText="Notification Service — sibling microservice")

AddComponentTag("interface",      $bgColor="#1168BD", $fontColor="#ffffff", $borderColor="#0B4884", $legendText="Interface Layer REST")
AddComponentTag("application",    $bgColor="#1168BD", $fontColor="#ffffff", $borderColor="#0B4884", $legendText="Application Layer CQRS")
AddComponentTag("domain",         $bgColor="#0B4884", $fontColor="#ffffff", $borderColor="#062F5A", $legendText="Domain Layer")
AddComponentTag("infrastructure", $bgColor="#6BA3DC", $fontColor="#000000", $borderColor="#438DD5", $legendText="Infrastructure Layer")
AddComponentTag("aclPayment",     $bgColor="#F5A97F", $fontColor="#000000", $borderColor="#C87A4C", $legendText="Payment Gateway ACL")
AddComponentTag("aclIam",         $bgColor="#B8C4CE", $fontColor="#000000", $borderColor="#7D98B5", $legendText="IAM Context ACL")

AddSystemTag("externalPayment",   $bgColor="#E63946", $fontColor="#ffffff", $borderColor="#9B1E28", $legendText="External Payment Gateway")
AddContainerTag("database",       $bgColor="#20B2AA", $fontColor="#ffffff", $borderColor="#148F89", $legendText="Relational SQL Database")

title Component Diagram — Subscription Bounded Context

' =========================================================
' Client
' =========================================================
Container(webApp, "Web Client App", "TypeScript / Angular PWA", "PWA para administradores de clínica — gestiona planes y suscripciones", $tags="webApp")

' =========================================================
' Subscription Service internal layers
' =========================================================
Container_Boundary(subscriptionService, "Subscription Service — RESTful API") {
  Component(interfaceLayer,      "Subscription Interface Layer",       "Component: Java 17 / Spring Boot 3", "Controllers y endpoints REST — Subscriptions, Plans, Invoices", $tags="interface")
  Component(applicationLayer,    "Subscription Application Layer",     "Component: Java 17 / Spring Boot 3", "Servicios CQRS que coordinan commands, queries y event handlers del dominio Subscription", $tags="application")
  Component(culqiAcl,            "Culqi Payments Service ACL",         "Component: Java 17 / Spring Boot 3", "Fachada ACL hacia Culqi — crea cobros, valida tokens y consume webhooks de confirmación de pago", $tags="aclPayment")
  Component(iamAcl,              "IAM Context Service ACL",            "Component: Java 17 / Spring Boot 3", "Fachada ACL hacia el BC IAM para validar clinicAdmin y asociar la suscripción a su clínica", $tags="aclIam")
  Component(domainLayer,         "Subscription Domain Layer",          "Component: Java 17 / Spring Boot 3", "Aggregate Subscription, Entities SubscriptionPlan e Invoice, Value Objects y eventos de dominio", $tags="domain")
  Component(infrastructureLayer, "Subscription Infrastructure Layer",  "Component: Java 17 / Spring Boot 3", "Repositorios JPA, scheduler de renovaciones, integración con Notification Service y plantillas de facturación", $tags="infrastructure")
}

' =========================================================
' External systems / sibling services / database
' =========================================================
System_Ext(culqi,         "Culqi — Payment Gateway",       "Sistema externo de pagos peruano", $tags="externalPayment")
Container(iamService,     "IAM Service",                   "Java / Spring Boot",                "Contexto hermano — expone perfil clínico vía ACL", $tags="iamService")
Container(notifService,   "Notification Service",          "Java / Spring Boot",                "Contexto hermano — envía correos transaccionales vía Resend", $tags="notifService")
ContainerDb(subscriptionDB, "Subscription Relational SQL Database", "Container: Azure Database for PostgreSQL", "Almacena planes, suscripciones, periodos y facturas del contexto Subscription", $tags="database")

' =========================================================
' Relations — vertical flow
' =========================================================
Rel(webApp, interfaceLayer, "Hace llamadas API hacia", "JSON/HTTPS")

Rel(interfaceLayer, applicationLayer, "Invoca servicios de la capa de aplicación")

Rel(applicationLayer, culqiAcl,            "Delega cobros y reconciliación de pagos", "in-process call")
Rel(applicationLayer, iamAcl,              "Obtiene perfil y clinicId del administrador", "in-process call")
Rel(applicationLayer, domainLayer,         "Orquesta casos de uso del dominio")
Rel(applicationLayer, infrastructureLayer, "Usa infraestructura — repos JPA, scheduler y notificaciones")

Rel(culqiAcl,            culqi,        "Crea cobros, procesa webhooks y consulta transacciones", "HTTPS")
Rel(iamAcl,              iamService,   "Consulta perfil clínico y valida rol CLINIC_ADMIN",      "HTTPS")
Rel(infrastructureLayer, notifService, "Solicita envío de correos de facturación",                "HTTPS")
Rel(infrastructureLayer, subscriptionDB, "Persistencia — commands y queries",                     "JDBC/SSL")

SHOW_LEGEND()
@enduml
