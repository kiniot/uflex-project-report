@startuml arthrotech-planning-component
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

' Styling
skinparam shadowing false
skinparam defaultFontName Arial
skinparam wrapWidth 200
skinparam nodesep 40
skinparam ranksep 60

' ---- Tags ----
AddContainerTag("kmpApp",     $bgColor="#806EE3", $fontColor="#ffffff", $borderColor="#5A4E9E", $legendText="KMP Mobile App (Kotlin Multiplatform)")
AddContainerTag("webApp",     $bgColor="#438DD5", $fontColor="#ffffff", $borderColor="#2E6295", $legendText="Web Client App")

AddComponentTag("interface",      $bgColor="#1168BD", $fontColor="#ffffff", $borderColor="#0B4884", $legendText="Interface Layer REST")
AddComponentTag("application",    $bgColor="#1168BD", $fontColor="#ffffff", $borderColor="#0B4884", $legendText="Application Layer CQRS")
AddComponentTag("domain",         $bgColor="#0B4884", $fontColor="#ffffff", $borderColor="#062F5A", $legendText="Domain Layer")
AddComponentTag("infrastructure", $bgColor="#6BA3DC", $fontColor="#000000", $borderColor="#438DD5", $legendText="Infrastructure Layer")
AddComponentTag("acl",            $bgColor="#F5A97F", $fontColor="#000000", $borderColor="#C87A4C", $legendText="External ACL")

AddContainerTag("database",  $bgColor="#20B2AA", $fontColor="#ffffff", $borderColor="#148F89", $legendText="Relational SQL Database")

title Component Diagram — Planning Bounded Context

' =========================================================
' Clients
' =========================================================
Container(kmpApp, "KMP Mobile App", "Kotlin Multiplatform", "App compartida para pacientes (Android/iOS)", $tags="kmpApp")
Container(webApp, "Web Client App", "TypeScript / Angular", "Gestión para fisioterapeutas y administradores", $tags="webApp")

' =========================================================
' Planning Service internal layers
' =========================================================
Container_Boundary(planningService, "Planning Service — RESTful API") {
  Component(interfaceLayer,      "Planning Interface Layer",   "Component: Spring Boot 3", "Controllers: TreatmentPlan, ClinicalDischarge", $tags="interface")
  Component(applicationLayer,    "Planning Application Layer", "Component: Spring Boot 3", "Handlers de Commands/Queries y Event Handlers", $tags="application")
  Component(planningFacade,      "Planning Context Facade",    "Component: Spring Boot 3", "Fachada para otros BCs (Therapy, Device)", $tags="acl")
  Component(domainLayer,         "Planning Domain Layer",      "Component: Spring Boot 3", "Aggregate TreatmentPlan, VO TargetROM, PlanStatus", $tags="domain")
  Component(infrastructureLayer, "Planning Infra Layer",       "Component: Spring Boot 3", "Repositorios JPA y Adaptadores de Inventario", $tags="infrastructure")
}

' =========================================================
' External systems & database
' =========================================================
ContainerDb(planningDB, "Planning SQL Database", "Azure Database for PostgreSQL", "Almacena planes, metas y reportes clínicos", $tags="database")

' =========================================================
' Relations
' =========================================================
Rel(kmpApp, interfaceLayer, "Consulta plan activo", "JSON/HTTPS")
Rel(webApp, interfaceLayer, "Gestiona planes y altas", "JSON/HTTPS")

Rel(interfaceLayer, applicationLayer, "Invoca servicios de aplicación")
Rel(applicationLayer, domainLayer, "Orquesta lógica del tratamiento")
Rel(applicationLayer, infrastructureLayer, "Persistencia y validación externa")

Rel(planningFacade, applicationLayer, "Expone funcionalidad a otros BCs", "in-process")
Rel(infrastructureLayer, planningDB, "Persistencia de datos", "JDBC/SSL")

SHOW_LEGEND()
@enduml